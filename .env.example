# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it contains your credentials

# Your Discord bot token
# Steps to create one:
#   1. Go to https://discord.com/developers/applications
#   2. Click "New Application" and give it a name (e.g. "Chinese Daily")
#   3. Go to the "Bot" tab and click "Reset Token"
#   4. Copy the token and paste it below
#   5. Under "Privileged Gateway Intents", enable "Message Content Intent"
#   6. Go to OAuth2 → URL Generator, select scopes: "bot" + "applications.commands"
#      then select permissions: Send Messages, Read Message History, Add Reactions, Attach Files
#   7. Use the generated URL to invite the bot to your server
DISCORD_TOKEN=your_bot_token_here

# Your Discord user ID (the person who receives the DMs)
# To find it:
#   1. Open Discord Settings → Advanced → enable "Developer Mode"
#   2. Right-click your username → "Copy User ID"
DISCORD_DM_USER_ID=123456789012345678

# (Optional) Discord server ID for instant slash command sync during development
# Without this, global commands can take up to an hour to propagate
# To find it: right-click your server name → "Copy Server ID" (Developer Mode must be on)
TEST_GUILD_ID=your_server_id_for_testing
