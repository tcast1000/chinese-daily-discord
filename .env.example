# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it contains your credentials

# Your Gmail address
GMAIL_USER=you@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Steps to create one:
#   1. Enable 2-Factor Authentication on your Google account
#      https://myaccount.google.com/security
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create a new app password (call it "Chinese Daily")
#   4. Paste the 16-character code below (no spaces)
GMAIL_APP_PASSWORD=abcdabcdabcdabcd

# Your phone number's email-to-SMS address
# Find your carrier below and replace 10digitnumber with your number:
#
#   AT&T:        10digitnumber@txt.att.net
#   T-Mobile:    10digitnumber@tmomail.net
#   Verizon:     10digitnumber@vtext.com
#   Sprint:      10digitnumber@messaging.sprintpcs.com
#   Cricket:     10digitnumber@mms.cricketwireless.net
#   Boost:       10digitnumber@sms.myboostmobile.com
#   Metro PCS:   10digitnumber@mymetropcs.com
#   US Cellular: 10digitnumber@email.uscc.net
#
SMS_EMAIL=5551234567@tmomail.net
